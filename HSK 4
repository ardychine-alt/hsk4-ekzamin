<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{--bg:#080810;--s1:#0E0E1A;--s2:#13131F;--s3:#1A1A2E;--p:#A78BFA;--p2:#7C3AED;--g:#34D399;--y:#FCD34D;--b:#60A5FA;--t:#FFFFFF;--t2:#E2E8F0;--m:#94A3B8;--br:rgba(167,139,250,.12);}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--t);font-family:'Outfit',sans-serif;display:flex;flex-direction:column;}
.hdr{flex-shrink:0;padding:16px 18px 12px;background:rgba(8,8,16,.97);backdrop-filter:blur(24px);border-bottom:1px solid var(--br);z-index:10;}
.hdr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.hdr-logo{display:flex;align-items:center;gap:10px;}
.logo-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--p2),var(--p));border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Noto Sans SC',sans-serif;font-size:16px;font-weight:900;color:white;box-shadow:0 0 20px rgba(124,58,237,.4);}
.logo-text{font-size:18px;font-weight:800;color:var(--t);}
.logo-text span{background:linear-gradient(90deg,var(--p),var(--b));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hdr-stats{display:flex;align-items:center;gap:6px;background:var(--s2);border:1px solid var(--br);border-radius:20px;padding:6px 12px;}
.hdr-stat-n{font-size:15px;font-weight:700;color:var(--p);}
.hdr-stat-l{font-size:11px;color:var(--m);}
.hdr-divider{width:1px;height:16px;background:var(--br);}
.search-box{position:relative;}
.search-ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--m);font-size:14px;pointer-events:none;}
.search-in{width:100%;background:var(--s2);border:1px solid var(--br);border-radius:12px;padding:10px 14px 10px 38px;font-size:14px;font-weight:500;color:var(--t);font-family:'Outfit',sans-serif;outline:none;transition:border-color .2s;}
.search-in:focus{border-color:rgba(167,139,250,.4);box-shadow:0 0 0 3px rgba(167,139,250,.08);}
.search-in::placeholder{color:var(--m);}
.chips{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;padding:10px 18px 2px;flex-shrink:0;}
.chips::-webkit-scrollbar{display:none;}
.chip{flex-shrink:0;padding:5px 13px;border-radius:20px;border:1px solid var(--br);background:transparent;color:var(--m);font-size:12px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;white-space:nowrap;}
.chip.on{background:rgba(167,139,250,.15);border-color:rgba(167,139,250,.4);color:var(--p);}
.prog-wrap{padding:0 18px 10px;flex-shrink:0;}
.prog-bg{height:3px;background:var(--s3);border-radius:2px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--p2),var(--p),var(--b));border-radius:2px;transition:width .6s;box-shadow:0 0 8px rgba(167,139,250,.5);}
.scroll{flex:1;overflow-y:auto;padding:12px 18px 120px;scrollbar-width:thin;scrollbar-color:var(--s3) transparent;}
.scroll::-webkit-scrollbar{width:4px;}
.scroll::-webkit-scrollbar-thumb{background:var(--s3);border-radius:2px;}
.lesson-grp{margin-bottom:8px;}
.lesson-btn{width:100%;background:var(--s2);border:1px solid var(--br);border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;text-align:left;font-family:'Outfit',sans-serif;transition:border-color .15s;}
.lesson-btn.open{border-color:rgba(167,139,250,.25);background:rgba(167,139,250,.05);border-radius:14px 14px 0 0;}
.ln-num{width:32px;height:32px;background:linear-gradient(135deg,var(--p2),var(--p));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:white;flex-shrink:0;}
.ln-info{flex:1;}
.ln-zh{font-family:'Noto Sans SC',sans-serif;font-size:15px;font-weight:700;color:var(--t);margin-bottom:2px;}
.ln-tk{font-size:12px;color:var(--m);}
.ln-right{display:flex;align-items:center;gap:8px;}
.ln-prog{font-size:11px;color:var(--p);font-weight:600;}
.ln-arrow{font-size:12px;color:var(--m);transition:transform .2s;}
.lesson-btn.open .ln-arrow{transform:rotate(180deg);}
.words-list{background:var(--s1);border:1px solid var(--br);border-top:none;border-radius:0 0 14px 14px;overflow:hidden;display:none;margin-bottom:8px;}
.words-list.open{display:block;}
.word-row{display:flex;align-items:center;gap:10px;padding:13px 16px;border-bottom:1px solid rgba(255,255,255,.05);cursor:pointer;transition:background .15s;}
.word-row:active{background:rgba(255,255,255,.04);}
.word-row.learned{background:rgba(52,211,153,.04);}
.wr-zh{font-family:'Noto Sans SC',sans-serif;font-size:28px;font-weight:700;flex-shrink:0;min-width:56px;line-height:1;color:var(--t);transition:color .2s;}
.word-row.learned .wr-zh{color:var(--g);}
.wr-mid{flex:1;}
.wr-py{font-size:13px;color:#FCD34D;font-weight:600;margin-bottom:4px;letter-spacing:.3px;display:block;}
.wr-tk{font-size:15px;font-weight:700;color:var(--t);line-height:1.3;margin-bottom:3px;}
.wr-type{font-size:11px;color:var(--m);}
.mark-btn{width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(255,255,255,.15);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;color:var(--m);transition:all .15s;flex-shrink:0;}
.mark-btn.on{background:rgba(52,211,153,.15);border-color:rgba(52,211,153,.5);color:var(--g);}
.ex-row{display:none;padding:12px 16px 14px 16px;background:rgba(167,139,250,.05);border-top:1px solid rgba(167,139,250,.1);}
.ex-row.open{display:block;}
.ex-bar{width:24px;height:2px;background:linear-gradient(90deg,var(--p),var(--b));border-radius:1px;margin-bottom:8px;}
.ex-zh{font-family:'Noto Sans SC',sans-serif;font-size:15px;color:var(--t);margin-bottom:4px;line-height:1.5;}
.ex-py{font-size:12px;color:var(--p);font-style:italic;margin-bottom:4px;line-height:1.5;}
.ex-tk{font-size:13px;color:var(--m);line-height:1.4;}
.empty{text-align:center;padding:60px 20px;color:var(--m);}
.empty-zh{font-family:'Noto Sans SC',sans-serif;font-size:40px;margin-bottom:10px;opacity:.15;}
.toast{position:fixed;top:80px;left:50%;transform:translateX(-50%) translateY(-10px);background:var(--s3);border:1px solid var(--br);color:var(--t);padding:9px 18px;border-radius:20px;font-size:13px;font-weight:600;opacity:0;transition:all .25s;pointer-events:none;white-space:nowrap;z-index:999;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.bnav{position:fixed;bottom:0;left:0;right:0;background:rgba(8,8,16,.98);backdrop-filter:blur(24px);border-top:1px solid var(--br);padding:10px 0 24px;display:flex;z-index:50;}
.bn-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;font-size:9px;font-weight:600;color:var(--m);letter-spacing:.5px;text-transform:uppercase;}
.bn-item.on{color:var(--p);}
.bn-ico{font-size:19px;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.word-row{animation:fadeIn .2s ease both;}
</style>
</head>
